{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:integration:mock",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit --coverage --coverage.include=convex/_lib/workflowUtils.ts",
    "test:integration:mock": "vitest run tests/integration/mock",
    "test:integration:convex": "vitest run tests/integration/convex",
    "test:all": "npm run test && npm run test:integration:convex",
    "import:sermons": "node scripts/import-sermons.mjs",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "convex": "^1.34.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "i18next": "^25.10.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.6.1",
    "react-router": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
