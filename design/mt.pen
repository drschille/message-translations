                      "name": "card1quote",
                      "fill": "#c3c6cf",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "\"For eksempel, hvis jeg hadde noe her… kunne jeg vist deg hva jeg mener. Her er ett segl...\"",
                      "lineHeight": 1.5,
                      "fontFamily": "Noto Serif",
                      "fontSize": 13,
                      "fontWeight": "normal",
                      "fontStyle": "italic"
