                        16
                      ],
                      "children": [
                        {
                          "type": "frame",
                          "id": "y6Ca3",
                          "name": "R3 NO Editable",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 10,
                          "children": [
                            {
                              "type": "frame",
                              "id": "veUkO",
                              "name": "Edit Box",
                              "width": "fill_container",
                              "fill": "#131313",
                              "stroke": {
                                "align": "inside",
                                "thickness": 0,
                                "fill": "#131313"
                              },
                              "layout": "vertical",
                              "padding": [
                                2,
                                0
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "E1kv5",
                                  "name": "r3no",
                                  "fill": "#e5e2e1",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Hvor mange her har lest Hva er Klokken, Herrer? eller har hørt den? Det har plaget meg en del. For omtrent en uke eller ti dager siden var jeg så urolig. En tidlig morgen bestemte jeg meg for å dra til Sabino Canyon. Fra huset tar det bare omtrent tretti minutter å kjøre til bunnen av dalen.",
                                  "lineHeight": 1.8,
                                  "fontFamily": "Noto Serif",
                                  "fontSize": 15,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        }
                      ]
