                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "tgGEe",
                      "name": "P4 Body",
                      "width": "fill_container",
                      "layout": "vertical",
                      "children": [
                        {
                          "type": "text",
                          "id": "17Pfc",
                          "name": "p4pre",
                          "fill": "#e5e2e1",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Har dere studert Jeremia og hvordan han skrev (mange av dere noterte det i går kveld)? Hvordan seglene ble skrevet og lagt bort for oppbevaring til han kom tilbake etter sytti år i fangenskap? Han kom tilbake og tok sitt eierskap. Jeg vil gjerne påpeke at det er umulig å uttrykke alt fordi det er et evig Ord.",
                          "lineHeight": 1.8,
                          "fontFamily": "Noto Serif",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "t0efQ",
                          "name": "Blue Highlight",
                          "width": "fit_content(908)",
                          "fill": "#60a5fa20",
