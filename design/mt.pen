                      ],
                      "children": [
                        {
                          "type": "frame",
                          "id": "wOqiz",
                          "name": "R2 NO Editable",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 10,
                          "children": [
                            {
                              "type": "frame",
                              "id": "KvF6m",
                              "name": "Edit Box",
                              "width": "fill_container",
                              "fill": "#1c1b1b",
                              "stroke": {
                                "align": "inside",
                                "thickness": 0,
                                "fill": "#1c1b1b"
                              },
                              "layout": "vertical",
                              "padding": [
                                2,
                                0
