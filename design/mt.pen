                    {
                      "type": "text",
                      "id": "cuFNZ",
                      "name": "card1note",
                      "fill": "#e5e2e1",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Seglene vises som opprullede deler av en bokrull. Når hvert segl brytes, åpnes en bestemt del av bokens mysterium.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    },
                    {
