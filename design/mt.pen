                      "height": "fill_container"
                    },
                    {
                      "type": "frame",
                      "id": "I5WFy",
                      "name": "R4 NO",
                      "width": "fill_container",
                      "layout": "vertical",
                      "padding": [
                        0,
                        0,
                        0,
                        16
                      ],
                      "children": [
                        {
                          "type": "frame",
                          "id": "ydzs6",
                          "name": "R4 NO Editable",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 10,
                          "children": [
                            {
                              "type": "frame",
                              "id": "DvWhF",
                              "name": "Edit Box",
                              "width": "fill_container",
                              "fill": "#1c1b1b",
                              "stroke": {
                                "align": "inside",
                                "thickness": 0,
                                "fill": "#1c1b1b"
                              },
                              "layout": "vertical",
                              "padding": [
                                2,
                                0
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "bmhn9",
                                  "name": "r4no",
                                  "fill": "#e5e2e1",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Vi var nylig i Phoenix, hvor det var rundt 28 grader. De hadde oppvarmet svømmebasseng; folk badet. Og bare en førti minutters kjøretur derfra, i Flagstaff, var det førti kuldegrader. Dette skyldes forskjellen mellom oppstrømningene og ørkenen.",
                                  "lineHeight": 1.8,
                                  "fontFamily": "Noto Serif",
                                  "fontSize": 15,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
