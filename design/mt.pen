              "children": [
                {
                  "type": "text",
                  "id": "yrr08",
                  "name": "aboutTag",
                  "fill": "#a8c9f4",
                  "content": "VÅR MISJON",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "600",
                  "letterSpacing": 3
                },
                {
                  "type": "text",
                  "id": "S01sr",
                  "name": "aboutHeading",
                  "fill": "#e5e2e1",
                  "content": "Hvem er vi?",
                  "fontFamily": "Noto Serif",
                  "fontSize": 36,
                  "fontWeight": "500"
                },
                {
                  "type": "text",
                  "id": "j4Q5M",
                  "name": "aboutP1",
                  "fill": "#c3c6cf",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Vi er en gruppe troende som arbeider med å gjøre William Marrion Branhams budskap tilgjengelig på norsk. Vårt mål er å bevare og dele dette viktige materialet for kommende generasjoner.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "gDdIb",
                  "name": "aboutP2",
                  "fill": "#c3c6cf",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Gjennom nøyaktige oversettelser og et digitalt arkiv ønsker vi å gjøre det enkelt for norsktalende å utforske og studere disse tidløse talene.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
