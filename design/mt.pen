                          "gap": 10,
                          "children": [
                            {
                              "type": "frame",
                              "id": "1WfI6",
                              "name": "Edit Box",
                              "width": "fill_container",
                              "fill": "#131313",
                              "stroke": {
                                "align": "inside",
                                "thickness": 0,
                                "fill": "#131313"
                              },
                              "layout": "vertical",
                              "padding": [
                                2,
                                0
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "qAvX3",
                                  "name": "r1no",
                                  "fill": "#e5e2e1",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "God kveld, venner. Det er et stort privilegium å være tilbake her i Herrens hus i kveld under møtet, og fortsatt leve på mannaen fra i morges, som våre sjeler ble så rikelig velsignet av Hans store nærvær. I kveld starter vi på emnet Brudd Mellom De Syv Menighetsalderene og De Syv Seglene.",
                                  "lineHeight": 1.8,
                                  "fontFamily": "Noto Serif",
                                  "fontSize": 15,
                                  "fontWeight": "normal"
                                }
