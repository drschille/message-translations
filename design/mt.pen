                          "name": "R3 NO Editable",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 10,
                          "children": [
                            {
                              "type": "frame",
                              "id": "veUkO",
                              "name": "Edit Box",
                              "width": "fill_container",
                              "fill": "#131313",
